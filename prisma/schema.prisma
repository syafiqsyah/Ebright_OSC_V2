generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model attendance {
  attendance_id  Int              @id @default(autoincrement())
  user_id        Int
  date           DateTime         @db.Date
  check_in       DateTime?        @db.Timestamptz(6)
  check_out      DateTime?        @db.Timestamptz(6)
  status         String           @default("present") @db.VarChar(50)
  leave_id       Int?
  total_hours    Decimal?         @db.Decimal(5, 2)
  device_id      Int?
  devices        devices?         @relation(fields: [device_id], references: [device_id], onUpdate: NoAction, map: "fk_attendance_device")
  leave_request  leave_request?   @relation(fields: [leave_id], references: [leave_id], onUpdate: NoAction, map: "fk_attendance_leave")
  users          users            @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_attendance_user")
  attendance_log attendance_log[]

  @@unique([user_id, date], map: "uq_attendance_user_date")
}

model attendance_log {
  log_id        Int         @id @default(autoincrement())
  user_id       Int
  scan_time     DateTime    @db.Timestamptz(6)
  scan_type     String      @db.VarChar(10)
  device_id     Int?
  scan_serial   String?     @db.VarChar(100)
  attendance_id Int?
  scan_time_myt DateTime?   @default(dbgenerated("(scan_time AT TIME ZONE 'Asia/Kuala_Lumpur'::text)")) @db.Timestamp(6)
  attendance    attendance? @relation(fields: [attendance_id], references: [attendance_id], onUpdate: NoAction, map: "fk_attendance_log_attendance")
  devices       devices?    @relation(fields: [device_id], references: [device_id], onUpdate: NoAction, map: "fk_log_device")
  users         users       @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_log_user")

  @@unique([device_id, scan_serial], map: "uq_attendance_log_device_serial", where: raw("(scan_serial IS NOT NULL)"))
}

model bank_details {
  bank_id      Int     @id @default(autoincrement())
  user_id      Int     @unique
  bank_name    String? @db.VarChar(100)
  bank_account String? @db.VarChar(50)
  account_name String? @db.VarChar(200)
  users        users   @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_bank_user")
}

model branch {
  branch_id          Int                 @id @default(autoincrement())
  branch_name        String              @db.VarChar(100)
  location           String?             @db.VarChar(255)
  branch_code        String?             @unique @db.VarChar(10)
  region             String?             @db.VarChar(10)
  devices            devices[]
  employment         employment[]
  manpower_schedules manpower_schedule[]
}

model department {
  department_id   Int                          @id @default(autoincrement())
  department_name String                       @db.VarChar(100)
  department_code String                       @unique @db.VarChar(10)
  employment      employment[]
  substep_templates induction_substep_template[]
}

model devices {
  device_id         Int              @id @default(autoincrement())
  serial_no         String           @unique @db.VarChar(100)
  branch_id         Int?
  ip_address        String?          @db.VarChar(45)
  tz_offset_minutes Int              @default(0)
  attendance        attendance[]
  attendance_log    attendance_log[]
  branch            branch?          @relation(fields: [branch_id], references: [branch_id], onUpdate: NoAction, map: "fk_devices_branch")
}

model emergency_contact {
  contract_id Int     @id(map: "emergency_contract_pkey") @default(autoincrement())
  user_id     Int
  name        String  @db.VarChar(255)
  phone       String? @db.VarChar(30)
  relation    String? @db.VarChar(50)
  users       users   @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_contract_user")
}

model employment {
  employment_id   Int         @id @default(autoincrement())
  user_id         Int
  employee_id     String?     @unique @db.VarChar(50)
  branch_id       Int?
  department_id   Int?
  position        String?     @db.VarChar(100)
  start_date      DateTime?   @db.Date
  end_date        DateTime?   @db.Date
  employment_type String?     @db.VarChar(50)
  status          String?     @default("active") @db.VarChar(50)
  probation       Boolean     @default(false)
  rate            String?     @db.VarChar(100)
  // Re-added 2026-05-07 after a prior schema-vs-DB drift caused `prisma db push`
  // to drop this column with 9 rows of data. Type set to VarChar(50) to match
  // the surrounding `rate` convention; if old values were stored differently,
  // change the type here and re-push.
  working_hours   String?     @db.VarChar(50)
  branch          branch?     @relation(fields: [branch_id], references: [branch_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_employment_branch")
  department      department? @relation(fields: [department_id], references: [department_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_employment_department")
  users           users       @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_employment_user")
}

model leave_request {
  leave_id                               Int          @id @default(autoincrement())
  user_id                                Int
  leave_type_id                          Int
  start_date                             DateTime     @db.Date
  end_date                               DateTime     @db.Date
  total_days                             Decimal      @db.Decimal(5, 2)
  reason                                 String?
  attachment                             String?      @db.VarChar(255)
  status                                 String       @default("pending") @db.VarChar(50)
  applied_at                             DateTime     @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime     @default(now()) @db.Timestamptz(6)
  approved_by                            Int?
  approved_at                            DateTime?    @db.Timestamptz(6)
  remarks                                String?
  attendance                             attendance[]
  users_leave_request_approved_byTousers users?       @relation("leave_request_approved_byTousers", fields: [approved_by], references: [user_id], onUpdate: NoAction, map: "fk_leave_approver")
  leave_types                            leave_types  @relation(fields: [leave_type_id], references: [leave_type_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_leave_type")
  users_leave_request_user_idTousers     users        @relation("leave_request_user_idTousers", fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_leave_user")
}

model leave_types {
  leave_type_id   Int             @id @default(autoincrement())
  leave_type_code String          @unique @db.VarChar(10)
  name            String          @db.VarChar(100)
  leave_request   leave_request[]
}

model role {
  role_id   Int     @id @default(autoincrement())
  role_type String  @unique @db.VarChar(50)
  users     users[]
}

model user_profile {
  profile_id   Int       @id @default(autoincrement())
  user_id      Int       @unique
  full_name    String    @db.VarChar(255)
  nick_name    String?   @db.VarChar(255)
  gender       String?   @db.VarChar(20)
  dob          DateTime? @db.Date
  phone        String?   @db.VarChar(30)
  nationality  String?   @db.VarChar(100)
  nric         String?   @unique @db.VarChar(30)
  home_address String?
  users        users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_profile_user")
}

model users {
  user_id                                        Int                 @id @default(autoincrement())
  email                                          String              @unique @db.VarChar(255)
  password                                       String?             @db.VarChar(255)
  role_id                                        Int
  status                                         String?             @default("active") @db.VarChar(50)
  last_login                                     DateTime?           @db.Timestamptz(6)
  created_at                                     DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                                     DateTime            @default(now()) @db.Timestamptz(6)
  deleted_at                                     DateTime?           @db.Timestamptz(6)
  attendance                                     attendance[]
  attendance_log                                 attendance_log[]
  bank_details                                   bank_details?
  claim                                          claim[]
  emergency_contact                              emergency_contact[]
  employment                                     employment[]
  leave_request_leave_request_approved_byTousers leave_request[]     @relation("leave_request_approved_byTousers")
  leave_request_leave_request_user_idTousers     leave_request[]     @relation("leave_request_user_idTousers")
  user_profile                                   user_profile?
  induction_profile                              induction_profile?  @relation("inductionProfile")
  induction_buddy_for                            induction_profile[] @relation("inductionBuddy")
  induction_created                              induction_profile[] @relation("inductionCreatedBy")
  induction_responsible                          induction_step[]    @relation("inductionResponsible")
  induction_completed                            induction_step[]    @relation("inductionCompletedBy")
  induction_request_user                         induction_request[] @relation("induction_request_user")
  induction_request_triggered_by                 induction_request[] @relation("induction_request_triggered_by")
  assigned_recommendations                       recommendation[]    @relation("recommendation_assigned_to")
  manpower_schedules                             manpower_schedule[]
  role                                           role                @relation(fields: [role_id], references: [role_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_users_role")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model claim {
  claim_id          Int      @id @default(autoincrement())
  claim_type        String   @db.VarChar(20)
  claim_description String?
  amount            Decimal  @db.Decimal(10, 2)
  claim_date        DateTime @db.Date
  status            String   @default("pending") @db.VarChar(20)
  attachment        String?  @db.VarChar(500)
  submitted_on      DateTime @default(now()) @db.Timestamptz(6)
  approved_amount   Decimal? @db.Decimal(10, 2)
  remarks           String?
  user_id           Int
  updated_at        DateTime @default(now()) @db.Timestamptz(6)
  users             users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_claim_user")

  @@index([claim_date], map: "idx_claim_date")
  @@index([status], map: "idx_claim_status")
  @@index([user_id], map: "idx_claim_user_id")
}

model induction_profile {
  id                Int       @id @default(autoincrement())
  user_id           Int       @unique
  induction_type    String    @default("Onboarding") @db.VarChar(20)
  workflow_template String    @default("Standard") @db.VarChar(50)
  buddy_user_id     Int?
  link_token        String    @unique @db.VarChar(128)
  link_expires_at   DateTime  @db.Timestamptz(6)
  status            String    @default("Created") @db.VarChar(20)
  start_date        DateTime  @db.Date
  exit_date         DateTime? @db.Date
  // How many days HR assigns this induction to last. Used for the dashboard
  // "expected end" calculation. NULL = fall back to the template default
  // (Coach Part-timer ≈ 21, all other paths ≈ 3).
  target_duration_days Int?
  // Date on which the onboarding "welcome + credentials" email should go
  // out to the candidate. Defaults to start_date in the Add Employee
  // form but HR can pick an earlier/later date. NULL = no email scheduled
  // (older rows or HR opted out).
  send_email_on     DateTime? @db.Date
  // Stamped by the cron job (/api/jobs/send-onboarding-emails) the first
  // time it successfully dispatches the email. Used as the idempotency
  // guard so the cron never sends twice.
  email_sent_at     DateTime? @db.Timestamptz(6)
  // Plaintext temp password held only between save-employee time and
  // when the cron job dispatches the welcome email — the same value
  // HR sees in the credential overlay. Cleared (set to NULL) by the
  // cron the moment it sends, so the plaintext lives at most until
  // send_email_on + a cron tick. NULL once email_sent_at is set.
  pending_email_password String? @db.VarChar(255)
  created_by        Int
  completed_at      DateTime? @db.Timestamptz(6)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime  @updatedAt @db.Timestamptz(6)

  user                  users                  @relation("inductionProfile", fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_induction_profile_user")
  buddy                 users?                 @relation("inductionBuddy", fields: [buddy_user_id], references: [user_id], onDelete: SetNull, onUpdate: NoAction, map: "fk_induction_profile_buddy")
  creator               users                  @relation("inductionCreatedBy", fields: [created_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_induction_profile_creator")
  steps                 induction_step[]
  onboarding_candidates onboarding_candidate[]
  survey_responses      survey_response[]      @relation("survey_responses")

  @@index([link_token], map: "idx_induction_profile_token")
  @@index([created_by], map: "idx_induction_profile_creator")
  @@index([buddy_user_id], map: "idx_induction_profile_buddy")
  @@index([status], map: "idx_induction_profile_status")
}

model induction_step {
  id                   Int       @id @default(autoincrement())
  induction_profile_id Int
  step_number          Int
  title                String    @db.VarChar(200)
  description          String?
  responsible_user_id  Int?
  due_date             DateTime  @db.Date
  status               String    @default("Pending") @db.VarChar(20)
  completed_at         DateTime? @db.Timestamptz(6)
  completed_by         Int?
  notes                String?
  evidence_file_id     String?   @db.VarChar(128)
  evidence_uploaded_at DateTime? @db.Timestamptz(6)
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime  @updatedAt @db.Timestamptz(6)

  induction_profile  induction_profile @relation(fields: [induction_profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_induction_step_profile")
  responsible_person users?            @relation("inductionResponsible", fields: [responsible_user_id], references: [user_id], onDelete: SetNull, onUpdate: NoAction, map: "fk_induction_step_responsible")
  completed_by_user  users?            @relation("inductionCompletedBy", fields: [completed_by], references: [user_id], onDelete: SetNull, onUpdate: NoAction, map: "fk_induction_step_completer")

  @@unique([induction_profile_id, step_number], map: "uq_induction_step_profile_number")
  @@index([induction_profile_id], map: "idx_induction_step_profile")
  @@index([responsible_user_id], map: "idx_induction_step_responsible")
  @@index([status], map: "idx_induction_step_status")
}

// Department / branch-level mini-workflow attached to a parent step in a
// workflow template (e.g. "Department Training" on Standard.15, "3-Week Branch
// Training" on CoachPartTimer.15). Defined once per template; shared across
// every inductee on that template.
model induction_substep_template {
  id                  Int      @id @default(autoincrement())
  template_key        String   @db.VarChar(50)
  parent_step_number  Int
  // Department-scoped sub-tasks. NULL = global (legacy / applies to anyone
  // on this template). When set, only inductees whose employment.department_id
  // matches will see this sub-task in their auto-generated sub-workflow.
  department_id       Int?
  title               String   @db.VarChar(200)
  description         String?
  // What the employee must submit to complete this sub-task.
  // One of: photo | video | screenshot | document | text | none.
  evidence_type       String   @default("photo") @db.VarChar(20)
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  updated_at          DateTime @updatedAt @db.Timestamptz(6)

  department department? @relation(fields: [department_id], references: [department_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_induction_substep_template_department")

  @@index([template_key, parent_step_number], map: "idx_induction_substep_template_parent")
  @@index([department_id], map: "idx_induction_substep_template_department")
}

model induction_request {
  id                   Int       @id @default(autoincrement())
  user_id              Int
  triggered_by_id      Int
  status               String    @default("pending") @db.VarChar(50)
  triggered_at         DateTime  @default(now()) @db.Timestamptz(6)
  accepted_at          DateTime? @db.Timestamptz(6)
  induction_profile_id Int?
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime  @updatedAt @db.Timestamptz(6)

  user         users @relation("induction_request_user", fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_induction_request_user")
  triggered_by users @relation("induction_request_triggered_by", fields: [triggered_by_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_induction_request_triggered_by")

  @@unique([user_id], map: "uq_induction_request_user_active", where: raw("status <> 'completed'"))
  @@index([status], map: "idx_induction_request_status")
  @@index([triggered_by_id], map: "idx_induction_request_triggered_by")
  @@index([created_at], map: "idx_induction_request_created_at")
}

model onboarding_candidate {
  id                   Int                @id @default(autoincrement())
  source_id            Int                @unique
  name                 String             @db.VarChar(200)
  position             String             @db.VarChar(200)
  department_branch    String             @db.VarChar(200)
  candidate_type       String             @db.VarChar(20)
  start_date           DateTime           @db.Date
  end_date             DateTime?          @db.Date
  synced_at            DateTime           @default(now()) @db.Timestamptz(6)
  updated_at           DateTime           @updatedAt @db.Timestamptz(6)
  induction_profile_id Int?
  induction_profile    induction_profile? @relation(fields: [induction_profile_id], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_onboarding_candidate_profile")

  @@index([candidate_type], map: "idx_onboarding_candidate_type")
  @@index([synced_at], map: "idx_onboarding_candidate_synced_at")
}

model survey_template {
  id               Int               @id @default(autoincrement())
  milestone        String            @unique @db.VarChar(20)
  questions        Json
  created_at       DateTime          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime          @updatedAt @db.Timestamptz(6)
  survey_responses survey_response[]
}

model survey_response {
  id                   Int               @id @default(autoincrement())
  induction_profile_id Int
  survey_template_id   Int
  responses            Json
  sentiment_score      Int?
  submitted_at         DateTime          @db.Timestamptz(6)
  created_at           DateTime          @default(now()) @db.Timestamptz(6)
  induction_profile    induction_profile @relation("survey_responses", fields: [induction_profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_survey_response_profile")
  survey_template      survey_template   @relation(fields: [survey_template_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_survey_response_template")

  @@index([induction_profile_id], map: "idx_survey_response_profile")
}

model analytics_metric {
  id          Int      @id @default(autoincrement())
  metric_name String   @db.VarChar(100)
  value       Float
  cohort      Json?
  timestamp   DateTime @default(now()) @db.Timestamptz(6)
  trend       String?  @db.VarChar(20)

  @@index([metric_name, timestamp], map: "idx_analytics_metric_name_time")
}

model recommendation {
  id               Int          @id @default(autoincrement())
  title            String       @db.VarChar(255)
  evidence         String
  action_items     Json
  assigned_to      Int?
  status           String       @default("New") @db.VarChar(20)
  priority         String       @db.VarChar(20)
  due_date         DateTime?    @db.Date
  completed_at     DateTime?    @db.Timestamptz(6)
  impact_metric_id Int?
  impact_before    Float?
  impact_after     Float?
  created_at       DateTime     @default(now()) @db.Timestamptz(6)
  updated_at       DateTime     @updatedAt @db.Timestamptz(6)
  assigned_user    users?       @relation("recommendation_assigned_to", fields: [assigned_to], references: [user_id], onDelete: SetNull, onUpdate: NoAction, map: "fk_recommendation_assigned_to")
  impact_logs      impact_log[]

  @@index([status], map: "idx_recommendation_status")
}

model impact_log {
  id                     Int            @id @default(autoincrement())
  recommendation_id      Int
  metric_name            String         @db.VarChar(100)
  value_before           Float
  value_after            Float
  improvement_percentage Float
  measured_at            DateTime       @db.Timestamptz(6)
  created_at             DateTime       @default(now()) @db.Timestamptz(6)
  recommendation         recommendation @relation(fields: [recommendation_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_impact_log_recommendation")

  @@index([recommendation_id], map: "idx_impact_log_recommendation")
}

model mc_record {
  id                Int      @id @default(autoincrement())
  source_id         Int      @unique
  name              String   @db.VarChar(200)
  position          String   @db.VarChar(200)
  department_branch String   @db.VarChar(200)
  mc_date           DateTime @db.Date
  reason            String?
  synced_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @updatedAt @db.Timestamptz(6)

  @@index([mc_date], map: "idx_mc_record_date")
}

model annual_leave_record {
  id                Int      @id @default(autoincrement())
  source_id         Int      @unique
  name              String   @db.VarChar(200)
  position          String   @db.VarChar(200)
  department_branch String   @db.VarChar(200)
  al_date           DateTime @db.Date
  al_duration       String?  @db.VarChar(50)
  synced_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @updatedAt @db.Timestamptz(6)

  @@index([al_date], map: "idx_annual_leave_record_date")
}

model manpower_schedule {
  manpower_id         Int      @id @default(autoincrement())
  branch_id           Int
  user_id             Int
  start_date          DateTime @db.Date
  end_date            DateTime @db.Date
  selections          Json     @default("{}")
  notes               Json     @default("{}")
  original_selections Json     @default("{}")
  original_notes      Json     @default("{}")
  status              String   @default("Finalized") @db.VarChar(50)
  submitted_at        DateTime @default(now()) @db.Timestamptz(6)
  branch              branch   @relation(fields: [branch_id], references: [branch_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_manpower_schedule_branch")
  users               users    @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_manpower_schedule_user")

  @@unique([branch_id, start_date], map: "uq_manpower_schedule_branch_week")
  @@index([branch_id, start_date(sort: Desc)], map: "idx_manpower_schedule_branch_date")
  @@index([status], map: "idx_manpower_schedule_status")
}
